# ==============================================================================
# Transcription Provider Configuration
# ==============================================================================

# Specify which transcription provider to use (optional)
# If not specified, the system will auto-detect based on available API keys
# Available providers: palatine, nexara, parakeetv3
TRANSCRIPTION_PROVIDER=palatine

# ==============================================================================
# Palatine Provider Configuration (RECOMMENDED - High accuracy Russian provider)
# ==============================================================================
# Get your API key from: https://speech.palatine.ru/
PALATINE_API_KEY=your_palatine_api_key_here

# Optional Palatine settings
# PALATINE_API_URL=https://api.palatine.ru/api/v1/audio/transcriptions
# PALATINE_MODEL=palatine_audio
# PALATINE_TIMEOUT=180000
# PALATINE_MAX_RETRIES=3

# Language detection (RECOMMENDED: leave unset for auto-detection)
# By default, Palatine auto-detects language from audio
# Only set to force specific language: PALATINE_LANGUAGE=ru or PALATINE_LANGUAGE=en
# PALATINE_LANGUAGE=

# ==============================================================================
# Nexara Provider Configuration (Alternative)
# ==============================================================================
# Get your API key from: https://nexara.ru/
# NEXARA_API_KEY=your_nexara_api_key_here

# Optional Nexara settings
# NEXARA_API_URL=https://api.nexara.ru/api/v1/audio/transcriptions
# NEXARA_MODEL=whisper-1
# NEXARA_TIMEOUT=120000
# NEXARA_MAX_RETRIES=10

# ==============================================================================
# Parakeet V3 Provider Configuration (LOCAL CPU - No API key needed!)
# ==============================================================================
# Local offline transcription using nvidia/parakeet-tdt-0.6b-v3
# Supports 25 European languages (English, Russian, German, French, etc.)
# Model stays in RAM for fast subsequent transcriptions (~5 seconds first load)
#
# Setup:
#   1. Install npm packages:
#      npm install sherpa-onnx-node sherpa-onnx-linux-x64
#
#   2. Download model (~640MB):
#      mkdir -p models && cd models
#      wget https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8.tar.bz2
#      tar xvf sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8.tar.bz2
#
#   3. Set path below and change TRANSCRIPTION_PROVIDER=parakeetv3
#
#   4. Run with LD_LIBRARY_PATH (already set in run.sh):
#      export LD_LIBRARY_PATH=./node_modules/sherpa-onnx-linux-x64:$LD_LIBRARY_PATH
#
# IMPORTANT: Parakeet requires WAV input, so compression is auto-disabled
#
# TRANSCRIPTION_PROVIDER=parakeetv3
# PARAKEET_MODEL_PATH=./models/sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8
# PARAKEET_NUM_THREADS=4
# ENABLE_COMPRESSION=false
#
# Daemon mode: process stays in memory, model stays loaded for instant transcription
# Enabled automatically when TRANSCRIPTION_PROVIDER=parakeetv3
# PARAKEET_DAEMON_MODE=true

# ==============================================================================
# Add more providers here as they are implemented
# ==============================================================================

# Example: OpenAI Whisper API
# TRANSCRIPTION_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

# Example: AssemblyAI
# TRANSCRIPTION_PROVIDER=assemblyai
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# ==============================================================================
# Application Settings
# ==============================================================================

# Optional: Disable sound notifications (default: enabled)
# SOUND_NOTIFICATIONS=false

# Audio Compression Settings (ffmpeg required: sudo apt install ffmpeg)
# Compress audio before uploading to reduce bandwidth (5-10x smaller files)
# Supported formats: opus (recommended for speech), mp3
# ENABLE_COMPRESSION=true
# COMPRESSION_FORMAT=opus
# COMPRESSION_BITRATE=32k

# Backup Settings
# Delete backup recordings after successful transcription (default: true)
# Set to 'false' to keep all backup recordings in var/recordings/
# DELETE_BACKUP_AFTER_SUCCESS=false

# Optional: Maximum number of backup recordings to keep (default: 5)
# Only applies when automatic deletion is enabled
# MAX_BACKUP_RECORDINGS=5